# Copy this file to .env.local and fill in your own values.

# Supabase — required (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenRouter — optional. Enables AI-generated explanations using free models.
# Without it, the app falls back to a high-quality rules-based explanation.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: force a specific model (tried before the built-in free-model chain)
# OPENROUTER_MODEL=moonshotai/kimi-k2.6:free

# Resend — optional. Enables a confirmation email after each recommendation.
# Without it, email is skipped gracefully. Get a key at https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=Acdyon <onboarding@resend.dev>
